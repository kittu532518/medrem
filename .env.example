# ─────────────────────────────────────────────
#  MedRem API — Environment Variables
#  Copy this file to packages/api/.env and fill in your values
# ─────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────
# Your Anthropic API key (get one free at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# JWT secret — any long random string
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ── DATABASE ───────────────────────────────────
# Local dev uses SQLite automatically (no config needed).
# DB file is created at packages/api/medrem.db
# For production PostgreSQL, set this and swap db.js for the pg Pool version:
# DATABASE_URL=postgresql://medrem:medrem_pass@localhost:5432/medrem

# ── WEB PUSH (VAPID) ──────────────────────────
# Run once to generate: cd packages/api && npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BBndEAcEkQoYxeBLuh0TExXhc2ELklotCLJnzluGMJJVVZfBXV_-BiN4G-8lNYTcxhyo0P5GcIHuzagZo0IzFjM
VAPID_PRIVATE_KEY=tsbl45ZOvfCThEBOeZStrBtiBTijs8KYAC_0H8RIflk
VAPID_EMAIL=mailto:dev@medrem.app

# ── SERVER ────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── LOCAL FILE STORAGE ────────────────────────
# Uploaded photos are saved here during dev.
# Swap for S3 by updating services/storage.js (stub is ready).
UPLOAD_DIR=./src/uploads

# ── SMS (TWILIO) — OPTIONAL ───────────────────
# Leave blank in dev — caregiver alerts log to console instead.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_FROM_PHONE=+91XXXXXXXXXX

# ── OTP DEV MODE ──────────────────────────────
# In development, OTP '123456' is always accepted for any phone number.
# The real generated OTP is also printed to the console.
# Set to 'false' to disable the dev shortcut:
# DEV_OTP_BYPASS=true
