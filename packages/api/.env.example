# ── Required ──────────────────────────────────────────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth ──────────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=change_me_to_a_long_random_string_in_production

# ── SuperAdmin ────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=medrem_admin_2024

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# Default: ./medrem.db (relative to packages/api/)
# DB_PATH=/data/medrem.db

# ── Web Push Notifications (optional) ────────────────────────
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:you@example.com

# ── Twilio OTP (optional — uses mock OTP 123456 without this) ─
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1...
